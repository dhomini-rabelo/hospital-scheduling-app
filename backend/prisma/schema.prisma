generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model TeamMember {
  id         String   @id @default(uuid())
  name       String
  profession String
  specialty  String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  scheduleEntryTeamMemberMaps ScheduleEntryTeamMemberMap[]

  @@map("team_members")
}

model ScheduleEntry {
  id        String   @id @default(uuid())
  date      String   @unique
  structure String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teamMembers ScheduleEntryTeamMemberMap[]

  @@map("schedule_entries")
}

model ScheduleEntryTeamMemberMap {
  id              String        @id @default(uuid())
  scheduleEntryId String        @map("schedule_entry_id")
  teamMemberId    String        @map("team_member_id")
  scheduleEntry   ScheduleEntry @relation(fields: [scheduleEntryId], references: [id], onDelete: Cascade)
  teamMember      TeamMember    @relation(fields: [teamMemberId], references: [id])
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@unique([scheduleEntryId, teamMemberId])
  @@map("schedule_entry_team_members")
}

model ScheduleRequirement {
  id            String   @id @default(uuid())
  dateReference String   @unique @map("date_reference")
  requirements  String
  isEnabled     Boolean  @default(true) @map("is_enabled")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("schedule_requirements")
}
